+  .capability-grid,
+  .feature-columns {
+    grid-template-columns: 1fr;
+  }
+
+  .capability,
+  .capability + .capability,
+  .feature-columns article,
+  .feature-columns article + article {
+    min-height: auto;
+    padding: 1.4rem 0;
+    border-right: 0;
+    border-bottom: 1px solid var(--line);
+  }
+
+  .project-grid.three-column,
+  .grid.three {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+
+  .contact-band {
+    display: block;
+  }
+
+  .contact-band .actions {
+    margin-top: 1.5rem;
+  }
+}
+
+@media (max-width: 650px) {
+  .nav-inner,
+  .nav-container {
+    padding-block: 0.65rem;
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .nav-links {
+    width: 100%;
+    overflow-x: auto;
+    flex-wrap: nowrap;
+    padding-bottom: 0.15rem;
+  }
+
+  .nav-links a {
+    white-space: nowrap;
+  }
+
+  .hero-home {
+    padding-block: 4rem;
+  }
+
+  h1 {
+    font-size: clamp(2.7rem, 15vw, 4.4rem);
+  }
+
+  .featured-project {
+    grid-template-columns: 1fr;
+  }
+
+  .project-number {
+    display: none;
+  }
+
+  .project-heading {
+    display: block;
+  }
+
+  .project-type {
+    margin-top: 0.55rem;
+  }
+
+  .evidence-list,
+  .project-grid,
+  .grid.two,
+  .grid.three,
+  .project-grid.three-column,
+  .decision-list {
+    grid-template-columns: 1fr;
+  }
+
+  .project-directory a {
+    grid-template-columns: 1fr;
+    gap: 0.15rem;
+  }
+
+  .principle-list > div {
+    grid-template-columns: 42px minmax(0, 1fr);
+  }
+
+  .principle-list p {
+    grid-column: 2;
+  }
+
+  .footer-inner,
+  .footer-content {
+    align-items: flex-start;
+    flex-direction: column;
+    justify-content: center;
+    padding-block: 1.3rem;
+  }
+
+  .actions,
+  .buttons,
+  .button-row,
+  .link-row,
+  .project-links {
+    align-items: stretch;
+  }
+
+  .actions .button,
+  .actions .btn,
+  .buttons .button,
+  .buttons .btn,
+  .button-row .button,
+  .button-row .btn,
+  .link-row .button,
+  .link-row .btn,
+  .project-links .button,
+  .project-links .btn {
+    width: 100%;
+  }
+
+  .button.text-button {
+    border: 1px solid var(--green-200);
+    background: var(--paper);
+  }
+}
