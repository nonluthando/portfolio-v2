diff --git a/assets/js/project-filter.js b/assets/js/project-filter.js
new file mode 100644
index 0000000..dc6272c
--- /dev/null
+++ b/assets/js/project-filter.js
@@ -0,0 +1,54 @@
+(() => {
+  const filterButtons = Array.from(document.querySelectorAll(".skill-filter"));
+  const projectCards = Array.from(document.querySelectorAll("[data-skills]"));
+  const projectCount = document.querySelector("#project-count");
+  const emptyMessage = document.querySelector("#empty-filter-message");
+
+  if (!filterButtons.length || !projectCards.length) {
+    return;
+  }
+
+  const applyFilter = (selectedFilter) => {
+    let visibleCount = 0;
+
+    projectCards.forEach((card) => {
+      const skills = card.dataset.skills.split(/\s+/);
+      const shouldShow = selectedFilter === "all" || skills.includes(selectedFilter);
+
+      card.hidden = !shouldShow;
+      if (shouldShow) {
+        visibleCount += 1;
+      }
+    });
+
+    filterButtons.forEach((button) => {
+      const isActive = button.dataset.filter === selectedFilter;
+      button.classList.toggle("active", isActive);
+      button.setAttribute("aria-pressed", String(isActive));
+    });
+
+    if (projectCount) {
+      projectCount.textContent = `${visibleCount} ${visibleCount === 1 ? "project" : "projects"}`;
+    }
+
+    if (emptyMessage) {
+      emptyMessage.hidden = visibleCount !== 0;
+    }
+
+    const url = new URL(window.location.href);
+    if (selectedFilter === "all") {
+      url.searchParams.delete("skill");
+    } else {
+      url.searchParams.set("skill", selectedFilter);
+    }
+    window.history.replaceState({}, "", url);
+  };
+
+  filterButtons.forEach((button) => {
+    button.addEventListener("click", () => applyFilter(button.dataset.filter));
+  });
+
+  const requestedFilter = new URLSearchParams(window.location.search).get("skill");
+  const validFilter = filterButtons.some((button) => button.dataset.filter === requestedFilter);
+  applyFilter(validFilter ? requestedFilter : "all");
+})();
