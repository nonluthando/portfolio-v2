.page-header .supporting,
.project-hero .supporting {
  max-width: 760px;
  margin-top: 1.5rem;
  color: var(--muted);
  font-size: 1.08rem;
}

.project-grid,
.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.project-grid.three-column,
.grid.three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.project-tile,
.card,
.project-card,
.panel,
.note,
.timeline-item {
  display: flex;
  flex-direction: column;
  padding: 1.55rem;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  background: var(--paper);
}

.featured-tile {
  min-height: 420px;
  border-top: 4px solid var(--green-800);
}

.project-tile h3,
.card h3,
.project-card h3,
.panel h3,
.note h3,
.timeline-item h3 {
  margin-bottom: 0.7rem;
}

.project-tile p,
.card p,
.project-card p,
.panel p,
.note p,
.timeline-item p,
.muted {
  color: var(--muted);
}

.project-tile .actions,
.project-card .actions,
.project-card .link-row,
.project-card .project-links {
  margin-top: auto;
  padding-top: 1.4rem;
}

.tile-topline {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: start;
  margin-bottom: 1.8rem;
}

.tag-list,
.tags,
.pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
  margin-top: 1.2rem;
}

.tag-list span,
.tags span,
.pills span {
  padding: 0.28rem 0.5rem;
  border: 1px solid var(--green-200);
  border-radius: 5px;
  background: var(--green-100);
  color: var(--green-800);
  font-size: 0.72rem;
  font-weight: 750;
}

.profile-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.65fr);
  gap: clamp(2rem, 6vw, 6rem);
}

.profile-main {
  max-width: 760px;
}

.large-copy {
  margin-bottom: 1.3rem;
  color: #3e4b43;
  font-size: 1.2rem;
}

.profile-main > p:last-child {
  color: var(--muted);
}

.qualification-list {
  border-top: 4px solid var(--green-800);
  background: var(--cream);
}

.qualification-list > div {
  padding: 1.35rem;
  border-bottom: 1px solid rgba(41, 75, 58, 0.15);
}

.qualification-list span,
.qualification-list small {
  display: block;
  color: var(--muted);
  font-size: 0.76rem;
}

.qualification-list span {
  margin-bottom: 0.3rem;
  font-weight: 750;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.qualification-list strong {
  display: block;
  margin-bottom: 0.25rem;
  color: var(--green-950);
}

.principle-list {
  border-top: 1px solid var(--line);
}

.principle-list > div {
  display: grid;
  grid-template-columns: 60px minmax(180px, 0.6fr) minmax(0, 1fr);
  gap: 1rem;
  padding-block: 1.6rem;
  border-bottom: 1px solid var(--line);
}

.principle-list span {
  color: var(--green-500);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: 0.78rem;
  font-weight: 750;
}

.principle-list h3 {
  margin-bottom: 0;
}

.principle-list p {
  color: var(--muted);
}

.contact-band {
  display: flex;
  justify-content: space-between;
  align-items: end;
  gap: 2rem;
  border-top: 4px solid var(--green-800) !important;
}

.contact-band h2 {
  max-width: 720px;
}

.contact-band .actions {
  flex-shrink: 0;
  margin-top: 0;
}

.case-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.65fr);
  gap: clamp(2rem, 6vw, 6rem);
  align-items: end;
  padding-block: clamp(4rem, 9vw, 7rem);
}

.case-meta {
  border-top: 4px solid var(--green-800);
  background: var(--cream);
}

.case-meta div {
  padding: 1.1rem 1.25rem;
  border-bottom: 1px solid rgba(41, 75, 58, 0.14);
}

.case-layout,
.split {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.6fr);
  gap: clamp(2rem, 6vw, 6rem);
}

.case-main {
  max-width: 780px;
}

.case-main > p:last-child {
  color: var(--muted);
}

.case-note {
  align-self: start;
  padding: 1.4rem;
  border-left: 4px solid var(--green-800);
  background: var(--green-100);
}

.case-note span {
  display: block;
  margin-bottom: 0.55rem;
  color: var(--green-700);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.case-note p {
  color: var(--green-950);
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.45rem;
  line-height: 1.25;
}

.feature-columns {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  border-top: 1px solid rgba(41, 75, 58, 0.18);
}

.feature-columns article {
  padding: 1.7rem 1.7rem 0 0;
  border-right: 1px solid rgba(41, 75, 58, 0.18);
}

.feature-columns article + article {
  padding-left: 1.7rem;
}

.feature-columns article:last-child {
  border-right: 0;
}

.feature-columns h3 {
  margin-top: 0.5rem;
}

.feature-columns ul {
  margin: 1rem 0 0;
  padding-left: 1.1rem;
  color: var(--muted);
}

.feature-columns li + li {
  margin-top: 0.5rem;
}

.decision-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border-top: 1px solid var(--line);
  border-left: 1px solid var(--line);
}

.decision-list > div {
  min-height: 180px;
  padding: 1.5rem;
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.decision-list p {
  color: var(--muted);
}

.development-panel {
  display: grid;
  grid-template-columns: minmax(280px, 0.75fr) minmax(0, 1.25fr);
  gap: 2rem;
  padding: clamp(1.8rem, 4vw, 3rem);
  border-top: 4px solid var(--green-800);
  background: var(--cream);
}

.development-panel h2 {
  margin-bottom: 0;
}

.development-panel > p {
  color: var(--muted);
  font-size: 1.02rem;
}

.roadmap-list,
.timeline,
.fact-list {
  border-top: 1px solid var(--line);
}

.roadmap-list > div,
.timeline-item,
.fact-list > div {
  display: grid;
  grid-template-columns: 70px minmax(0, 1fr);
  gap: 1rem;
  padding: 1.35rem 0;
  border-bottom: 1px solid var(--line);
}

.roadmap-list > div > span {
  color: var(--green-500);
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: 0.78rem;
  font-weight: 750;
}

.roadmap-list h3 {
  margin-bottom: 0.3rem;
}

.roadmap-list p {
  color: var(--muted);
}

.footer {
  margin-top: 2rem;
  border-top: 1px solid rgba(41, 75, 58, 0.14);
  background: var(--cream);
}

.footer-inner,
.footer-content {
  min-height: 92px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  color: var(--muted);
  font-size: 0.86rem;
}

.center {
  text-align: center;
}

@media (max-width: 900px) {
  .hero-home,
  .case-hero,
  .profile-layout,
  .case-layout,
  .split,
  .experience-layout,
  .development-panel {
    grid-template-columns: 1fr;
  }

  .hero-home {
    min-height: auto;
  }

  .section-heading,
  .section-head,
  .section-header {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .capability-grid,
  .feature-columns {
    grid-template-columns: 1fr;
  }

  .capability,
  .capability + .capability,
  .feature-columns article,
  .feature-columns article + article {
    min-height: auto;
    padding: 1.4rem 0;
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }

  .project-grid.three-column,
  .grid.three {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact-band {
    display: block;
  }

  .contact-band .actions {
    margin-top: 1.5rem;
  }
}

@media (max-width: 650px) {
  .nav-inner,
  .nav-container {
    padding-block: 0.65rem;
    align-items: flex-start;
    flex-direction: column;
  }

  .nav-links {
    width: 100%;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 0.15rem;
  }

  .nav-links a {
    white-space: nowrap;
  }

  .hero-home {
    padding-block: 4rem;
  }

  h1 {
    font-size: clamp(2.7rem, 15vw, 4.4rem);
  }

  .featured-project {
    grid-template-columns: 1fr;
  }

  .project-number {
    display: none;
  }

  .project-heading {
    display: block;
  }

  .project-type {
    margin-top: 0.55rem;
  }

  .evidence-list,
  .project-grid,
  .grid.two,
  .grid.three,
  .project-grid.three-column,
  .decision-list {
    grid-template-columns: 1fr;
  }

  .project-directory a {
    grid-template-columns: 1fr;
    gap: 0.15rem;
  }

  .principle-list > div {
    grid-template-columns: 42px minmax(0, 1fr);
  }

  .principle-list p {
    grid-column: 2;
  }

  .footer-inner,
  .footer-content {
    align-items: flex-start;
    flex-direction: column;
    justify-content: center;
    padding-block: 1.3rem;
  }

  .actions,
  .buttons,
  .button-row,
  .link-row,
  .project-links {
    align-items: stretch;
  }

  .actions .button,
  .actions .btn,
  .buttons .button,
  .buttons .btn,
  .button-row .button,
  .button-row .btn,
  .link-row .button,
  .link-row .btn,
  .project-links .button,
  .project-links .btn {
    width: 100%;
  }

  .button.text-button {
    border: 1px solid var(--green-200);
    background: var(--paper);
  }
}
